// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int        @id @default(autoincrement())
  name     String
  phone    String
  address  String
  email    String     @unique
  password String
  cart     AddToCart?
}

model Admin {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}

model Product {
  id                Int         @id @default(autoincrement())
  name              String
  description       String
  detailDescription String
  productCategory   String[]
  productType       ProductType @relation(fields: [productTypeId], references: [id])
  productTypeId     Int
  images            String[]
  sizes             String[]
  colors            String[]
  note              String
  reviews           Review[]
  price             Int
  status            String
  addToCart         AddToCart[]
}

model Review {
  id        Int     @id @default(autoincrement())
  rating    Int
  author    String
  comment   String
  product   Product @relation(fields: [productId], references: [id])
  productId Int
}

model ProductCategory {
  id    Int    @id @default(autoincrement())
  name  String @unique
  image String
}

model ProductType {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model AddToCart {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  quantity  Int
  user      User    @relation(fields: [userId], references: [id])
  userId    Int     @unique
}

model ContactInfo {
  id      Int    @id @default(autoincrement())
  name    String
  email   String
  phone   String
  address String
}

model ContactMessage {
  id      Int    @id @default(autoincrement())
  name    String
  email   String
  phone   String
  message String
}

model About {
  id               Int           @id @default(autoincrement())
  title            String
  titleSub         String
  storyDescription String
  values           AboutValues[]
  team             TeamMembers[]
}

model AboutValues {
  id          Int    @id @default(autoincrement())
  title       String
  icon        String
  description String
  about       About  @relation(fields: [aboutId], references: [id])
  aboutId     Int
}

model TeamMembers {
  id     Int    @id @default(autoincrement())
  name   String
  role   String
  image  String
  team   About  @relation(fields: [teamId], references: [id])
  teamId Int
}

model AboutTeamNumbers {
  id               Int    @id @default(autoincrement())
  numberOne        String
  numberOneLabel   String
  numberTwo        String
  numberTwoLabel   String
  numberThree      String
  numberThreeLabel String
  numberFour       String
  numberFourLabel  String
}

model CompanyInfo {
  id          Int    @id @default(autoincrement())
  name        String
  email       String
  phone       String
  address     String
  description String
  otherSites  String
}

model WorkFlow {
  id                  Int    @id @default(autoincrement())
  number              String
  process             String
  workFlowDescription String
}

model SocialLinks {
  id            Int    @id @default(autoincrement())
  facebookLink  String
  instagramLink String
  twitterLink   String
  linkedinLink  String
}
